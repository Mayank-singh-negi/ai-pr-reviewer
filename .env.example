# Example environment variables for ai-pr-reviewer
# Copy to .env and fill values before running/deploying.

# GitHub API token with repo/comment permissions
GITHUB_TOKEN=

# Webhook secret used to validate GitHub webhooks
GITHUB_WEBHOOK_SECRET=

# Google Gemini API key (or other model key)
GEMINI_API_KEY=

# Allow automatic recreation of local ChromaDB persistence when initialization fails.
# Set to true if your stored Chroma data is non-critical and you prefer the service
# to recreate an empty DB instead of failing. Default: false
CHROMA_ALLOW_RECREATE=false

# Optional: override Chroma persist dir
# CHROMA_PERSIST_DIR=./chroma_db
# GitHub webhook secret used to validate incoming webhook payloads
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub personal access token for reading PR data
GITHUB_TOKEN=your_github_token_here

# Google Gemini API key for AI review generation
GEMINI_API_KEY=your_gemini_api_key_here
