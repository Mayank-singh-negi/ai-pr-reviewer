# GitHub webhook secret used to validate incoming webhook payloads
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub personal access token for reading PR data
GITHUB_TOKEN=your_github_token_here

# Anthropic API key placeholder for future AI integration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key (optional). If you prefer ChatGPT/OpenAI instead of Anthropic,
# set this and the pipeline will use OpenAI for reviews.
OPENAI_API_KEY=your_openai_api_key_here
